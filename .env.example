# 环境变量配置

# === LLM API 配置 ===
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
# 或使用其他兼容接口，如：
# LLM_BASE_URL=https://api.lkeap.cloud.tencent.com/v1

# === NapCat 网络配置 ===
# 连接模式选择:
#   - http_client: HTTP 回调模式（NapCat 推送到本项目）
#   - ws_server:   正向 WebSocket（本项目连接 NapCat）⭐ 开发推荐
#   - ws_client:   反向 WebSocket（NapCat 连接本项目）
NAPCAT_MODE=ws_server

# --- HTTP 模式配置 (当 NAPCAT_MODE=http_client) ---
NAPCAT_HTTP_URL=http://your-server-ip:23333
NAPCAT_HTTP_TOKEN=

# --- WebSocket 正向模式配置 (当 NAPCAT_MODE=ws_server) ---
# 本项目主动连接到 NapCat 的 WS 服务端
NAPCAT_WS_URL=ws://your-server-ip:3001
NAPCAT_WS_TOKEN=

# --- WebSocket 反向模式配置 (当 NAPCAT_MODE=ws_client) ---
# 本项目作为 WS Server，等待 NapCat 连接
NAPCAT_WS_SERVER_HOST=0.0.0.0
NAPCAT_WS_SERVER_PORT=7779

# === 本地服务器配置 ===
# HTTP 服务端口（用于 http_client 模式接收推送）
SERVER_HOST=0.0.0.0
SERVER_PORT=7778

# === 数据库配置 ===
DATABASE_PATH=data/dailylaid.db
