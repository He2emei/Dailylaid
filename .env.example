# 环境变量配置

# === LLM API 配置 ===
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
# 或使用其他兼容接口，如：
# LLM_BASE_URL=https://api.lkeap.cloud.tencent.com/v1

# === NapCat 配置 ===
# NapCat 运行的服务器地址
NAPCAT_BASE_URL=http://127.0.0.1:23333

# === 本地服务器配置 ===
SERVER_HOST=0.0.0.0
SERVER_PORT=7778

# === 数据库配置 ===
DATABASE_PATH=data/dailylaid.db
